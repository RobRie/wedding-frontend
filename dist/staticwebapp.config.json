{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*"
    ]
  },
  "routes": [
    {
      "route": "/api/*",
      "redirect": "https://www.google.de",
      "statusCode": 302,
      "allowedRoles": [
        "anonymous"
      ]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
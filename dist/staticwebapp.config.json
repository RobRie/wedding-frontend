{
  "trailingSlash": "auto",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*"
    ]
  },
  "routes": [
    {
      "route": "/api*",
      "redirect": "/login",
      "statusCode": 301,
      "allowedRoles": [
        "anonymous"
      ],
      "headers": {
        "location": "www.google.de"
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/login"
    }
  }
}
{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*"
    ]
  },
  "routes": [
    {
      "route": "api/*",
      "rewrite": "/login",
      "statusCode": 200,
      "allowedRoles": [
        "anonymous"
      ]
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}